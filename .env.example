# Udemy MCP Configuration
# Bu dosyayı .env olarak kopyalayın ve değerleri girin.

# Udemy Instructor API Bearer Token (KENDİ HESABINIZIN)
# DevTools > Network > herhangi bir instructor-api/v1 isteği > Authorization header'ından alın
UDEMY_INSTRUCTOR_TOKEN=

# Opsiyonel: ElevenLabs (seslendirme pipeline için)
ELEVENLABS_API_KEY=

# Opsiyonel: Browser scanner hız modu (yavas | normal | hizli)
SCANNER_MODE=yavas
